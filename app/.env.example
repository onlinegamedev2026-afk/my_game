# ============================================================
# Luck Game v7 — Environment Variables Template
# Copy this file to .env and fill in every change-me value.
# NEVER commit .env with real credentials.
# ============================================================

APP_NAME=Mumbai Dreams
APP_ENV=production
LOG_LEVEL=INFO

# ── Security ─────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-256-bit-secret
CSRF_SECRET=change-me-generate-a-real-csrf-secret
COOKIE_SECURE=true           # false only during initial HTTP smoke test
SESSION_TIMEOUT_HOUR=8

# ── Database — DigitalOcean Managed PostgreSQL ───────────────
# Use the Private hostname from the DO managed DB dashboard.
DB_HOST=change-me-private-db-hostname.db.ondigitalocean.com
DB_PORT=25060
DB_NAME=change-me-db-name
DB_USER=change-me-db-user
DB_PASSWORD=change-me-db-password
SERVER_TLS_SSLMODE=verify-ca
DB_POOL_MIN=4
DB_POOL_MAX=20
PGBOUNCER_MAX_CLIENT_CONN=500
PGBOUNCER_DEFAULT_POOL_SIZE=40

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
REDIS_PUBSUB_CHANNEL=luck_game_events

# ── Admin seed account ───────────────────────────────────────
ADMIN_USERNAME=change-me-admin-username
ADMIN_PASSWORD=change-me-strong-admin-password
ADMIN_EMAIL_ID=change-me-admin@example.com

# ── SMTP ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=change-me@gmail.com
SMTP_PASSWORD=change-me-gmail-app-password
SMTP_FROM_EMAIL=change-me@gmail.com
SMTP_USE_TLS=true
SMTP_DELETE_SENT_COPY=true
SMTP_IMAP_HOST=imap.gmail.com
SMTP_IMAP_PORT=993
SMTP_SENT_MAILBOX=[Gmail]/Sent Mail

# ── Game timing ──────────────────────────────────────────────
BETTING_WINDOW_SECONDS=40
GAME_INITIATION_SECONDS=10
AFTER_GAME_COOLDOWN_SECONDS=10
CARD_DRAWING_DELAY_SECONDS=3

# ── Scheduler & rate limiting ────────────────────────────────
GAME_SCHEDULER_ENABLED=false
RATE_LIMIT_ENABLED=true
